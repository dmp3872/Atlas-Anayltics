# Copy to .env and fill in from Supabase Dashboard → Project Settings → API
# Run migrations in supabase/migrations/ against your project (Supabase CLI or SQL editor).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# Comma-separated emails that get admin access in the UI (optional fallback if DB role not set)
VITE_ADMIN_EMAILS=you@example.com
